<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
    <AssemblyName>Nucleus.Commander</AssemblyName>
    <LangVersion>latest</LangVersion>
    <IsPackable>false</IsPackable>
    <PluginName>Nucleus.Commander</PluginName>
  </PropertyGroup>

  <Import Project="..\..\build\GameReferences.props" />
  <Import Project="..\..\build\Deploy.targets" />

  <!-- Shared libs Private=false (the platform ships them): only Nucleus.Commander.dll deploys. -->
  <ItemGroup>
    <ProjectReference Include="..\..\libs\Nucleus.Abstractions\Nucleus.Abstractions.csproj"><Private>false</Private></ProjectReference>
    <ProjectReference Include="..\..\libs\Nucleus.Domain\Nucleus.Domain.csproj"><Private>false</Private></ProjectReference>
    <ProjectReference Include="..\..\libs\Nucleus.Squads\Nucleus.Squads.csproj"><Private>false</Private></ProjectReference>
    <ProjectReference Include="..\..\libs\Nucleus.Production\Nucleus.Production.csproj"><Private>false</Private></ProjectReference>
    <ProjectReference Include="..\..\libs\Nucleus.Campaign\Nucleus.Campaign.csproj"><Private>false</Private></ProjectReference>
    <ProjectReference Include="..\..\libs\Nucleus.GameSdk\Nucleus.GameSdk.csproj"><Private>false</Private></ProjectReference>
    <ProjectReference Include="..\..\libs\Nucleus.Ui\Nucleus.Ui.csproj"><Private>false</Private></ProjectReference>
  </ItemGroup>
</Project>
